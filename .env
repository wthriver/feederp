# Server Configuration
NODE_ENV=development
PORT=3000
HOST=localhost

# Database Configuration
DB_TYPE=sqlite
DB_PATH=./data/feedmill.db

# For PostgreSQL (Production)
# DB_TYPE=postgresql
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=feedmill_erp
# DB_USER=postgres
# DB_PASSWORD=your_password

# JWT Configuration
JWT_SECRET=feedmill_erp_secret_key_2026_secure_random_string
JWT_EXPIRY=8h
JWT_REFRESH_EXPIRY=7d

# Bcrypt
BCRYPT_ROUNDS=10

# Application
APP_NAME=FeedMill ERP
APP_URL=http://localhost:3000
UPLOAD_PATH=./uploads
MAX_UPLOAD_SIZE=10mb

# Multi-tenant SaaS
DEFAULT_TENANT_ID=default
ENABLE_MULTI_TENANT=true

# IoT Settings
IOT_POLL_INTERVAL=5000
IOT_ENABLED=false
