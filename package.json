{
  "name": "feedmill-erp",
  "version": "2.0.0",
  "description": "Cattle Feed Manufacturing ERP System",
  "main": "server/index.js",
  "scripts": {
    "start": "node server/index.js",
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "server": "node server/index.js",
    "client": "npm run dev --prefix frontend",
    "build": "npm run build --prefix frontend",
    "build:client": "cd frontend && npm run build",
    "install:all": "npm install && cd frontend && npm install",
    "setup": "node scripts/setup-postgres.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:ci": "jest --ci --coverage --reporters=default --reporters=jest-junit"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "erp",
    "feedmill",
    "manufacturing",
    "cattle-feed",
    "production"
  ],
  "author": "FeedMill Team",
  "license": "MIT",
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "better-sqlite3": "^9.4.3",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "exceljs": "^4.4.0",
    "express": "^4.18.3",
    "express-rate-limit": "^7.2.0",
    "express-validator": "^7.0.1",
    "helmet": "^7.1.0",
    "joi": "^18.1.2",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^8.0.5",
    "otplib": "^13.4.0",
    "pdfkit": "^0.18.0",
    "pg": "^8.11.3",
    "prom-client": "^15.1.3",
    "redis": "^5.12.1",
    "socket.io": "^4.7.4",
    "uuid": "^9.0.1",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "jest": "^29.7.0"
  }
}